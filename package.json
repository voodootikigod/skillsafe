{
  "name": "skill-versions",
  "version": "0.1.0",
  "description": "Freshness checker for Agent Skills — like npm outdated for skill knowledge",
  "type": "module",
  "bin": {
    "skill-versions": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "agent-skills",
    "skill-versions",
    "freshness",
    "version-check",
    "npm-outdated",
    "cli"
  ],
  "author": "Vercel Professional Services <dept-solution-engineering@vercel.com>",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "gray-matter": "^4.0.3",
    "semver": "^7.7.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/node": "^22.0.0",
    "@types/semver": "^7.7.0",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18"
  }
}
