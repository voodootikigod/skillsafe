{
	"name": "skill-versions",
	"version": "0.1.0",
	"description": "Freshness checker for Agent Skills — like npm outdated for skill knowledge",
	"type": "module",
	"bin": {
		"skill-versions": "./dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsx src/index.ts",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"agent-skills",
		"skill-versions",
		"freshness",
		"version-check",
		"npm-outdated",
		"cli"
	],
	"author": "Chris Williams <voodootikigod@gmail.com>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/voodootikigod/skill-versions.git",
		"directory": "packages/cli"
	},
	"homepage": "https://skill-versions.com",
	"dependencies": {
		"ai": "^6.0.0",
		"chalk": "^5.4.1",
		"commander": "^14.0.0",
		"diff": "^8.0.0",
		"gray-matter": "^4.0.3",
		"semver": "^7.7.0",
		"zod": "^3.24.0"
	},
	"optionalDependencies": {
		"@ai-sdk/anthropic": "^3.0.0",
		"@ai-sdk/google": "^3.0.0",
		"@ai-sdk/openai": "^3.0.0"
	},
	"devDependencies": {
		"@skill-versions/schema": "*",
		"@types/node": "^22.0.0",
		"@types/semver": "^7.7.0",
		"tsup": "^8.5.0",
		"tsx": "^4.21.0",
		"typescript": "^5.8.0",
		"vitest": "^4.0.18"
	},
	"engines": {
		"node": ">=18"
	}
}
