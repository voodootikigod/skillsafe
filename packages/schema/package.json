{
	"name": "@skillsafe/schema",
	"version": "0.1.0",
	"description": "Shared types and JSON Schema for skillsafe registry format",
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./schema.json": "./dist/schema.json"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup && tsx src/generate.ts",
		"typecheck": "tsc --noEmit"
	},
	"license": "MIT",
	"devDependencies": {
		"ts-json-schema-generator": "^2.3.0",
		"tsup": "^8.5.0",
		"tsx": "^4.21.0",
		"typescript": "^5.8.0"
	}
}
